# Configuración del Backend
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
# Formato: mongodb+srv://<username>:<password>@<cluster>.slg9w99.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Secret - Genera una cadena aleatoria segura
JWT_SECRET=your-super-secret-jwt-key-here-generate-random-string